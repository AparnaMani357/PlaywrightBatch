

function makeRetryCount(max){
 let attempt=0;

    function retryCounter(){
        attempt++;
        if(attempt <= max){
            return `${attempt}/${max} attempts over`;
        }
        else return `Maximum retry count is over`
    }
    return retryCounter;
}

